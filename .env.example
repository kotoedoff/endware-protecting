# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Groq API Keys (Each has its own 20 RPM limit)
# Key 1 for general messages, text, and spam checks
GROQ_API_KEY_TEXT=your_groq_api_key_text_here
# Key 2 for photo checks (NSFW, illegal content)
GROQ_API_KEY_VISION=your_groq_api_key_vision_here

# Groq Model (unified Llama 4 Scout)
GROQ_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Global Bot Hoster Owner Telegram ID (Only this ID can access global settings)
OWNER_ID=123456789
